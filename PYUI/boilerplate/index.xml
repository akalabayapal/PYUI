<pyui>
    <metadata>
        <version>1.0.0</version>
    </metadata>

    <form-settings>
        <title>PyUI - Welcome Portal</title>
        <width>550</width>
        <height>650</height>
        <resizable>true</resizable>
    </form-settings>

    <style file="index.css"></style>

    <main-content default-active-window="view">
        <window id="view" style-class="app-wrapper">
            
            <container id="hero-card" style-class="card hero-section">
                <h1 id="main-title" style-class="heading" innerText="Welcome to PyUI 👋"></h1>
                <Para id="sub-title" style-class="subheading" innerText="Build sleek cross-platform desktop applications with ease."></Para>
            </container>

            <container id="interaction-card" style-class="card form-section">
                <label id="lbl-name" style-class="field-label" innerText="What should we call you?"></label>
                <Input id="input-name" style-class="text-input" placeholder="Enter your name..." type="text"></Input>
                <Button id="btn-submit" style-class="primary-button" innerText="Get Started"></Button>
            </container>

            <container id="status-card" style-class="card footer-section">
                <Text id="status-tag" style-class="status-badge" innerText="Username:" auto-hidden='true'></Text>
            </container>

        </window>
    </main-content>
</pyui>